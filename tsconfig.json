// tsconfig.json
{
	"compilerOptions": {
		// UPDATED: Modern enough for optional chaining (?.), supported by 96% of browsers
		"target": "ES2020", 
		"module": "ESNext",
    // This resolves the 'node10' deprecation warning.
		"moduleResolution": "bundler",
		"moduleDetection": "force",
		"strict": true,
		// --- The Clean-Up Crew ---
		"declaration": true,
		"declarationDir": "./dist/types",
		"outDir": "./dist",

		// FIX 2: Explicitly define the source root
		// This ensures your dist folder layout is predictable.
		"rootDir": "src",
		
		"lib": ["ES2020", "DOM"], // Explicitly include DOM for Canvas stuff
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"]
}